        </a>
        <a class="doc-card" href="/docs/target-resolver" hx-get="/docs/target-resolver" hx-target="#content" hx-push-url="true">
            <strong>Target resolver</strong>
            <span>Replace one dynamic row or card with fresh request-scoped data.</span>
        </a>
        <a class="doc-card" href="/docs/data-context" hx-get="/docs/data-context" hx-target="#content" hx-push-url="true">
