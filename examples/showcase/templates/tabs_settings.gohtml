<div class="tab-copy">
    <h2>Settings</h2>
    <p>Settings pages often make good tabs because each tab can stay small and focused while sharing the same parent context.</p>
    <div class="facts">
        <dt>Mode</dt>
        <dd>Server rendered</dd>
        <dt>Header</dt>
        <dd>{{ selectionValue }}</dd>
        <dt>Partial</dt>
        <dd>settings</dd>
    </div>
</div>
