    },
    {
      "name": "poll",
      "path": "github.com/donseba/go-partial/exp/interactions.Poll"
    },
    {
      "name": "on",
      "path": "github.com/donseba/go-partial/exp/interactions.On"
    },
    {
      "name": "stream",
      "path": "github.com/donseba/go-partial/exp/interactions.Stream"
    },
    {
      "name": "prefetch",
      "path": "github.com/donseba/go-partial/exp/interactions.Prefetch"
    },
    {
      "name": "refresh",
      "path": "github.com/donseba/go-partial/exp/interactions.Refresh"
    },
    {
      "name": "action",
      "path": "github.com/donseba/go-partial/exp/actions.ActionHTML"
    },
    {
      "name": "actionHeader",
      "path": "github.com/donseba/go-partial/exp/actions.ActionHeader"
    },
    {
      "name": "actionValue",
      "path": "github.com/donseba/go-partial/exp/actions.ActionValue"
    },
    {
      "name": "actionIs",
      "path": "github.com/donseba/go-partial/exp/actions.ActionIs"
    },
    {
      "name": "csrf",
      "path": "github.com/donseba/go-partial/exp/csrf.CSRF"
    },
    {
      "name": "locale",
      "path": "github.com/donseba/go-partial/exp/localization.Locale"
    },
    {
      "name": "localizer",
      "path": "github.com/donseba/go-partial/exp/localization.LocalizerValue"
    },
    {
      "name": "selection",
      "path": "github.com/donseba/go-partial/exp/selection.SelectionHTML"
    },
    {
      "name": "selectionHeader",
      "path": "github.com/donseba/go-partial/exp/selection.SelectionHeader"
    },
    {
      "name": "selectionValue",
      "path": "github.com/donseba/go-partial/exp/selection.SelectionValue"
    },
    {
      "name": "selectionIs",
      "path": "github.com/donseba/go-partial/exp/selection.SelectionIs"
    },
    {
      "name": "slot",
      "path": "github.com/donseba/go-partial/exp/slots.Slot"
    },
    {
      "name": "hasSlot",
      "path": "github.com/donseba/go-partial/exp/slots.HasSlot"
    },
    {
      "name": "targetHeader",
      "path": "github.com/donseba/go-partial/exp/target.TargetHeader"
    },
    {
      "name": "targetValue",
      "path": "github.com/donseba/go-partial/exp/target.TargetValue"
    },
    {
      "name": "targetIs",
      "path": "github.com/donseba/go-partial/exp/target.TargetIs"
    },
    {
      "name": "debug",
      "path": "github.com/donseba/go-partial/ext/debug.Debug"
    }
  ]
